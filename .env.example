# Puerto del servidor Express
PORT=4000
# Origen permitido por CORS (el dev server de Vite)
CORS_ORIGIN=http://localhost:5173
# Tamaño máximo del body JSON
BODY_LIMIT=1mb
# Ventana y máximo de peticiones para el rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Agente IA (DeepSeek, API compatible con OpenAI) ──
# Pega aquí TU key (este archivo es de ejemplo; el real .env NO se commitea).
DEEPSEEK_API_KEY=sk-tu-key-de-deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Nota: las tools del agente llaman a los servicios del backend EN PROCESO (no por HTTP),
# así que NO hace falta ninguna variable de URL propia (funciona igual en local y en Vercel).
