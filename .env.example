# Puerto del servidor Express
PORT=4000
# Origen permitido por CORS (el dev server de Vite)
CORS_ORIGIN=http://localhost:5173
# Tamaño máximo del body JSON (subido para permitir archivos base64)
BODY_LIMIT=6mb
# Ventana y máximo de peticiones para el rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Agente IA (DeepSeek, API compatible con OpenAI) ──
# Pega aquí TU key (este archivo es de ejemplo; el real .env NO se commitea).
DEEPSEEK_API_KEY=sk-tu-key-de-deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Nota: las tools del agente llaman a los servicios del backend EN PROCESO (no por HTTP),
# así que NO hace falta ninguna variable de URL propia (funciona igual en local y en Vercel).

# ── Base de datos (Supabase Postgres · pooler puerto 6543) ──
# Cadena completa de conexión del POOLER (pgBouncer). Si se deja vacía, el backend usa la
# semilla en memoria (sin persistencia). Formato:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-...pooler.supabase.com:6543/postgres
DATABASE_URL=

# Token para el endpoint destructivo POST /api/admin/reset-seed (reinicia la BD al seed).
# Si se deja vacío, ese endpoint queda deshabilitado (403).
RESET_TOKEN=
