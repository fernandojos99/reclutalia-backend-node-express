# Puerto del servidor Express
PORT=4000
# Origen permitido por CORS (el dev server de Vite)
CORS_ORIGIN=http://localhost:5173
# Tamaño máximo del body JSON (subido para permitir archivos base64)
BODY_LIMIT=6mb
# Ventana y máximo de peticiones para el rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Agente IA (DeepSeek, API compatible con OpenAI) ──
# Pega aquí TU key (este archivo es de ejemplo; el real .env NO se commitea).
DEEPSEEK_API_KEY=sk-e2b91247b2644c259cd47c3a1f4a64fd
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# (AGENT_API_BASE ya no se usa: las tools del agente llaman a los servicios en proceso.)

# ── Base de datos (Supabase Postgres · pooler 6543) ──
DATABASE_URL=postgresql://postgres.fskztcmytpmbqvuryedq:3UpfDCaOb9ESbl0X@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Token para POST /api/admin/reset-seed (reinicia la BD al seed).
