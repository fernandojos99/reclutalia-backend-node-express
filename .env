# Puerto del servidor Express
PORT=4000
# Origen permitido por CORS (el dev server de Vite)
CORS_ORIGIN=http://localhost:5173
# Tamaño máximo del body JSON
BODY_LIMIT=1mb
# Ventana y máximo de peticiones para el rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Agente IA (DeepSeek, API compatible con OpenAI) ──
# Pega aquí TU key (este archivo es de ejemplo; el real .env NO se commitea).
DEEPSEEK_API_KEY=sk-e2b91247b2644c259cd47c3a1f4a64fd
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# URL con la que las tools del agente llaman de vuelta al backend.
# Local: http://127.0.0.1:4000/api  |  Vercel: https://<tu-backend>.vercel.app/api
AGENT_API_BASE=http://127.0.0.1:4000/api
